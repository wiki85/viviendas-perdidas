{
  "name": "@viviendas-perdidas/functions",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "lib/index.js",
  "engines": {
    "node": "22"
  },
  "scripts": {
    "sync:geo": "node scripts/sync-geo.mjs",
    "prebuild": "npm run sync:geo",
    "build": "tsc -p tsconfig.build.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "eslint src --max-warnings=0",
    "pretest": "npm run sync:geo",
    "test": "vitest run",
    "test:integration": "vitest run --config vitest.integration.config.ts",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@turf/boolean-point-in-polygon": "^7.2.0",
    "@turf/helpers": "^7.2.0",
    "firebase-admin": "^13.4.0",
    "firebase-functions": "^6.4.0",
    "geofire-common": "^6.0.0",
    "zod": "^3.25.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.30.0",
    "@firebase/rules-unit-testing": "^5.0.1",
    "@types/geojson": "^7946.0.16",
    "@types/node": "^22.15.0",
    "eslint": "^9.30.0",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.35.0",
    "vitest": "^3.2.0"
  }
}
