{
  "functions": {
    "source": "functions",
    "runtime": "nodejs22",
    "ignore": ["node_modules", ".git", "firebase-debug.log", "firebase-debug.*.log", "*.local"],
    "predeploy": ["npm --prefix \"$RESOURCE_DIR\" run build"]
  },
  "firestore": {
    "rules": "firestore.rules",
    "indexes": "firestore.indexes.json"
  },
  "storage": {
    "rules": "storage.rules"
  },
  "hosting": {
    "public": "apps/web/dist",
    "ignore": ["firebase.json", "**/.*", "**/node_modules/**"],
    "cleanUrls": true,
    "trailingSlash": false,
    "rewrites": [
      {
        "source": "/compartir/**",
        "function": {
          "functionId": "shareScope",
          "region": "europe-southwest1"
        }
      },
      {
        "source": "/ciudad/**",
        "function": {
          "functionId": "cityPage",
          "region": "europe-southwest1"
        }
      },
      {
        "source": "/ciudades",
        "function": {
          "functionId": "cityPage",
          "region": "europe-southwest1"
        }
      },
      {
        "source": "/sitemap.xml",
        "function": {
          "functionId": "sitemap",
          "region": "europe-southwest1"
        }
      },
      {
        "source": "**",
        "destination": "/index.html"
      }
    ],
    "headers": [
      {
        "source": "/assets/**",
        "headers": [
          {
            "key": "Cache-Control",
            "value": "public,max-age=31536000,immutable"
          }
        ]
      },
      {
        "source": "/geo/manifest.json",
        "headers": [
          {
            "key": "Cache-Control",
            "value": "public,max-age=300,must-revalidate"
          }
        ]
      },
      {
        "source": "/geo/**/neighborhoods.*.geojson",
        "headers": [
          {
            "key": "Cache-Control",
            "value": "public,max-age=31536000,immutable"
          }
        ]
      },
      {
        "source": "/geo/**/neighborhoods.geojson",
        "headers": [
          {
            "key": "Cache-Control",
            "value": "public,max-age=3600,stale-while-revalidate=86400"
          }
        ]
      }
    ]
  },
  "emulators": {
    "functions": {
      "port": 5001
    },
    "firestore": {
      "port": 8080
    },
    "hosting": {
      "port": 5000
    },
    "ui": {
      "enabled": true,
      "port": 4000
    },
    "singleProjectMode": true
  }
}
