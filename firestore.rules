rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // Removed listings are intentionally undiscoverable. Collection queries must
    // include a compatible status filter so Firestore can prove this condition.
    match /listings/{listingId} {
      allow get, list: if resource.data.status is string
        && resource.data.status != 'removed';
      allow create, update, delete: if false;
    }

    match /aggregates/{scopeId} {
      allow read: if true;
      allow write: if false;
    }

    // Mirror of the public OpenRTA registry (Junta de Andalucía): read-only
    // public data, written exclusively by the sync function.
    match /officialVut/{recordId} {
      allow read: if true;
      allow write: if false;
    }

    match /officialStats/{cityId} {
      allow read: if true;
      allow write: if false;
    }

    // Votes, rate-limit buckets, and every future internal collection are
    // server-only. Admin SDK writes from Cloud Functions bypass these rules.
    match /votes/{voteId} {
      allow read, write: if false;
    }

    match /rateLimits/{document=**} {
      allow read, write: if false;
    }

    // Photo review queue: uploaded, listed, and approved exclusively through
    // Cloud Functions. Approved photos surface as `photo` on the listing doc.
    match /listingPhotos/{photoId} {
      allow read, write: if false;
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
